{
  "name": "veda-desktop",
  "version": "1.0.0",
  "description": "VEDA - AI Scientist Platform (Desktop App)",
  "main": "main.js",
  "scripts": {
    "start": "node -e \"require('child_process').spawn('node_modules/electron/dist/electron.exe', ['.'], {cwd: __dirname, stdio: 'inherit'})\"",
    "electron": "node_modules/electron/dist/electron.exe",
    "build": "electron-builder",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "ai.veda.desktop",
    "productName": "VEDA",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "icon.png"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../frontend/.next",
        "to": "frontend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    }
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1"
  }
}
